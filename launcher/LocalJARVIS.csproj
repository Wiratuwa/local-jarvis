<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows</TargetFramework>
    <UseWindowsForms>true</UseWindowsForms>
    <ApplicationIcon>..\assets\jarvis.ico</ApplicationIcon>
    <AssemblyName>LocalJARVIS</AssemblyName>
    <Description>One-click launcher for all Local JARVIS services</Description>
    <Company>JARVIS</Company>
    <Product>Local JARVIS</Product>
    <Version>1.0.0</Version>
  </PropertyGroup>
  <ItemGroup>
    <Content Include="..\assets\jarvis.ico" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>
</Project>
